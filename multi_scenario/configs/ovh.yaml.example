# OVH AI Training deployment config — copy to ovh.yaml and fill in.
# Loaded by `OvhJobConfig.from_yaml(...)`. Per-experiment YAMLs stay
# portable across runners; this file pins the OVH-specific bits.

region: GRA           # GRA / BHS / SBG / WAW
image: ovhcom/ai-training-pytorch:latest
flavor: ai1-1-gpu     # ovhai flavor — see `ovhai capabilities flavor list`
gpu_type: V100S       # cost-registry key (display only; flavor is what ovhai uses)
n_gpu: 1

# S3 buckets (your project's): code is mounted ``ro`` at submit-time;
# results bucket gets one per-experiment prefix (no trailing slash) so
# parallel jobs don't overwrite each other during OVH's FINALIZING sync.
bucket_code: my-multi-scenario-code
bucket_results: my-multi-scenario-results
mount_code: /workspace/code
mount_results: /workspace/results

# The runner is a bash command that runs INSIDE the OVH container. ``HOME=/tmp``
# is mandatory — pip can't write to /workspace. Substitution tokens:
# ``{mount_code}`` / ``{mount_results}`` / ``{yaml_path_in_container}`` (the
# absolute path to the experiment yaml inside the container, computed from
# OvhRunner.yaml_path_in_repo + mount_code).
default_runner: |
  export HOME=/tmp && pip install -e {mount_code} && cd {mount_code} && python -m multi_scenario.cli run {yaml_path_in_container}

# Polling cadence and timeout.
poll_interval_sec: 30.0
timeout_sec: 7200.0   # 2h default; bump for long matrix cells.

# Known GPU models with eur_per_hour for cost estimates. Wrong gpu_type
# fails loudly via OvhJobConfig.validate_gpu_choice.
gpu_models:
  V100S:
    eur_per_hour: 2.5
    description: NVIDIA V100S 32GB
  CPU:
    eur_per_hour: 0.0
    description: CPU-only (smoke debugging)
