{
  "experiment": {
    "id": "er1_cr035",
    "seed": 0,
    "name": "ER1 + AL + LP+SR (covering_range=0.35)",
    "description": "Reference baseline reproducing rendezvous_comm `er1_al_lp_sr_cr035`: 4 agents, 4 targets, k=2, covering_range=0.35, max_steps=200, agent lidar on, low collision penalty, shared reward. Headline reproducibility target: M1 ≈ 0.405 at 10M frames (seed 0).\n"
  },
  "scenario": {
    "type": "discovery",
    "params": {
      "n_agents": 4,
      "n_targets": 4,
      "agents_per_target": 2,
      "lidar_range": 0.35,
      "covering_range": 0.35,
      "use_agent_lidar": true,
      "n_lidar_rays_entities": 15,
      "n_lidar_rays_agents": 12,
      "targets_respawn": false,
      "shared_reward": true,
      "max_steps": 200,
      "agent_collision_penalty": -0.01,
      "covering_rew_coeff": 1.0,
      "time_penalty": -0.01
    }
  },
  "algorithm": {
    "type": "mappo",
    "params": {
      "lmbda": 0.95
    }
  },
  "training": {
    "max_iters": 167,
    "num_envs": 600,
    "device": "cuda",
    "lr": 0.00005,
    "gamma": 0.99,
    "frames_per_batch": 60000,
    "minibatch_size": 4096,
    "n_minibatch_iters": 45,
    "share_policy_params": true,
    "checkpoint_interval_iters": 10
  },
  "evaluation": {
    "interval_iters": 2,
    "episodes": 200
  },
  "runtime": {
    "runner": {
      "type": "ovh",
      "params": {
        "record_video": false
      }
    },
    "storage": {
      "type": "fs",
      "path": "/workspace/results",
      "params": {}
    }
  }
}