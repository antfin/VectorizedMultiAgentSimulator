# Python bytecode and packaging
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/

# Virtualenvs
.venv/
venv/
env/
.env

# Test and lint caches
.claude/
.pytest_cache/
.playwright-mcp/
.ruff_cache/
.mypy_cache/
.coverage
coverage.xml
htmlcov/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Experiment outputs — keep the directory tree (.gitkeep markers) but not the runs
experiments/**/results/*
!experiments/**/results/.gitkeep

# BenchMARL native output that leaks to CWD when run_dir isn't passed.
# Tests should always pass run_dir=tmp_path; this rule is a safety net.
/mappo_*/
/ippo_*/
/maddpg_*/
/iddpg_*/
/isac_*/
/masac_*/
